# LearnWise_AI LLM (default: self-hosted vLLM)
LEARNWISE_LLM_BACKEND=local_vllm
LEARNWISE_LLM_BASE_URL=http://127.0.0.1:8000/v1
LEARNWISE_LLM_MODEL=Qwen2.5-7B-Instruct
LEARNWISE_LLM_API_KEY=EMPTY
LEARNWISE_LLM_TEMPERATURE=0.7
LEARNWISE_LLM_MAX_TOKENS=4096

# vLLM serve (GPU machine)
LEARNWISE_MODEL_PATH=/root/autodl-tmp/models/Qwen2.5-7B-Instruct
LEARNWISE_VLLM_PORT=8000

# Web app
LEARNWISE_WEB_PORT=6006

# Fallback dev only
# DEEPSEEK_API_KEY=
# TONGYI_API_KEY=
