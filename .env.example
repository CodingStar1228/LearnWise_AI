# EasyEdu LLM (default: self-hosted vLLM)
EASYEDU_LLM_BACKEND=local_vllm
EASYEDU_LLM_BASE_URL=http://127.0.0.1:8000/v1
EASYEDU_LLM_MODEL=Qwen2.5-7B-Instruct
EASYEDU_LLM_API_KEY=EMPTY
EASYEDU_LLM_TEMPERATURE=0.7
EASYEDU_LLM_MAX_TOKENS=4096

# vLLM serve (GPU machine)
EASYEDU_MODEL_PATH=/root/autodl-fs/Qwen/Qwen2.5-7B-Instruct
EASYEDU_VLLM_PORT=8000

# Fallback dev only
# DEEPSEEK_API_KEY=
# TONGYI_API_KEY=
